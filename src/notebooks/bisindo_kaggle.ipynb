  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-link-dataset",
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "\n",
    "# Dataset Kaggle ada di /kaggle/input/slr-bisindo-landmarks/slr-bisindo-landmarks/\n",
    "KAGGLE_DATA = '/kaggle/input/slr-bisindo-landmarks/slr-bisindo-landmarks'\n",
    "\n",
    "# Struktur yang dibutuhkan kode:\n",
    "# ta-code/data/processed/npy/X.npy\n",
    "# ta-code/data/processed/npy/y.npy\n",
    "# ta-code/data/processed/npy/labels.npy\n",
    "\n",
    "os.makedirs('data/processed', exist_ok=True)\n",
    "os.makedirs('data/interim',   exist_ok=True)\n",
    "os.makedirs('outputs/checkpoints', exist_ok=True)\n",
    "os.makedirs('outputs/logs',        exist_ok=True)\n",
    "os.makedirs('outputs/plots',       exist_ok=True)\n",
    "\n",
    "# Symlink folder processed/npy → Kaggle dataset\n",
    "npy_link = 'data/processed/npy'\n",
    "if not os.path.exists(npy_link):\n",
    "    os.symlink(f'{KAGGLE_DATA}/processed/npy', npy_link)\n",
    "\n",
    "# Verifikasi\n",
    "import numpy as np\n",
    "X = np.load('data/processed/npy/X.npy')\n",
    "y = np.load('data/processed/npy/y.npy')\n",
    "labels = np.load('data/processed/npy/labels.npy', allow_pickle=True)\n",
    "\n",
    "print(f'X shape  : {X.shape}')\n",
    "print(f'y shape  : {y.shape}')\n",
    "print(f'Classes  : {list(labels)}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-run-experiments",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Jalankan semua 6 eksperimen\n",
    "# Output: outputs/logs/experiment_summary.json\n",
    "\n",
    "!python scripts/run_all.py"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-summary",
   "metadata": {},
   "outputs": [],
   "source": [
    "import json\n",
    "import pandas as pd\n",
    "\n",
    "with open('outputs/logs/experiment_summary.json') as f:\n",
    "    summary = json.load(f)\n",
    "\n",
    "rows = []\n",
    "for exp in summary['experiments']:\n",
    "    rows.append({\n",
    "        'Label':      exp['label'],\n",
    "        'Model':      exp.get('model', '-'),\n",
    "        'use_delta':  exp.get('use_delta', '-'),\n",
    "        'Accuracy':   f\"{exp['accuracy']:.4f}\" if exp.get('accuracy') else '-',\n",
    "        'F1-Macro':   f\"{exp['f1_macro']:.4f}\"  if exp.get('f1_macro')  else '-',\n",
    "        'Best Epoch': exp.get('best_epoch', '-'),\n",
    "        'Status':     exp['status'],\n",
    "    })\n",
    "\n",
    "df = pd.DataFrame(rows)\n",
    "print(df.to_string(index=False))"
   ]
  },
  {
   "cell_type": "code",
