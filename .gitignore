# ============================================================
#  .gitignore — SLR BISINDO
#  Dataset di-host di Kaggle: sigawari/slr-bisindo-landmarks
#  Download via: python scripts/download_dataset.py
# ============================================================


# 1. VIDEO & MEDIA *.mp4
*.avi
*.mov
*.mkv
*.gif


# 2. DATA — download via scripts/download_dataset.py 
data/raw/
data/interim/
data/processed/
data/_kaggle_tmp/

# Tetap lacak struktur folder
!data/**/.gitkeep


# 3. MODEL & CHECKPOINT *.pt
*.pth
*.onnx
*.h5
*.keras
outputs/checkpoints/
outputs/plots/

# Tetap lacak struktur folder
!outputs/**/.gitkeep


# 4. PYTHON CACHE __pycache__/
*.py[cod]
*$py.class
*.pyo


# 5. JUPYTER 
.ipynb_checkpoints/


# 6. LOGS & HASIL EKSPERIMEN 
outputs/logs/*.log
outputs/logs/*.json
wandb/

# Tetap lacak folder log
!outputs/logs/.gitkeep


# 7. IDE & TOOLING 
.vscode/
.idea/
*.swp
*.swo


# 8. ARSIP & EKSPERIMEN LAMA 
archive/
src_old/
try_result/
photo/


# 9. ZIP & TEMP *.zip
*.tar
*.tar.gz


# 10. PATH LAMA (sudah tidak dipakai) # Folder dataset/ dulu sebelum refactor ke data/
dataset/